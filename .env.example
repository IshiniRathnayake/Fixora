# Fixora — copy to .env and fill in values
#   Copy-Item .env.example .env

# Local dev without Docker: set USE_SQLITE=true
USE_SQLITE=true
SQLITE_PATH=./backend/data/fixora.db

# MySQL (when using Docker)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=fixora
MYSQL_PASSWORD=fixora_dev_password
MYSQL_DATABASE=fixora

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# xAI Grok (natural language & diagnostics)
XAI_API_KEY=
XAI_MODEL=grok-2-latest
XAI_BASE_URL=https://api.x.ai/v1

# Groq (fast agent intake, routing, escalation)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Gemini (resolution synthesis & complex reasoning)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,chrome-extension://*

# Log ingestion
LOG_BATCH_SIZE=500
ANOMALY_CONTAMINATION=0.05
